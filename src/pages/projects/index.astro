---
import Base from "@/layouts/Base.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getCollection } from "astro:content";
const projects = (await getCollection("projects"))
  .sort((a,b)=> b.data.date.localeCompare(a.data.date));
---
<Base title="Projects — Keith Curry" description="Project case studies covering research tools, imaging systems, and software engineering work by Keith Curry.">
  <section class="archive-hero">
    <p class="page-eyebrow">Works / Projects</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Projects</h1>
    <p class="lede mt-4 max-w-2xl">Longer case studies covering research automation, imaging systems, and infrastructure work.</p>
    <div class="archive-tags">
      <span class="folio-chip">Case studies</span>
      <span class="folio-chip">Measured outcomes</span>
      <span class="folio-chip">System constraints</span>
    </div>
  </section>
  <div class="mt-10 grid md:grid-cols-2 gap-6">
    {projects.map(({ slug, data }) => (
      <ProjectCard url={`/projects/${slug}/`} data={data} eyebrow="Case Study" />
    ))}
  </div>
</Base>
