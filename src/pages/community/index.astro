---
import Base from "@/layouts/Base.astro";
import SimpleCard from "@/components/SimpleCard.astro";
import { getCollection } from "astro:content";

const groupSections = [
  {
    id: "current",
    label: "Current",
    summary: "Active organizations, programs, and community-facing work.",
    order: [
      "sf-bay-acm",
      "internet-society",
      "sf-microscopical-society",
      "chatgpt-lab",
      "intern-ship",
    ],
  },
  {
    id: "past",
    label: "Previous / Selected Past Work",
    summary: "Earlier leadership, events, and selected community projects.",
    order: [
      "acm-sfsu",
      "sf-hacks-2025",
      "3d-printing-club",
      "wisdom-and-ai-conference",
    ],
  },
] as const;

const items = (await getCollection("community"))
  .filter((entry) => entry.data.showInIndex !== false)
  .filter((entry) => Boolean(entry.data.cover || entry.data.thumbs?.length))
  .sort((a,b)=> b.data.date.localeCompare(a.data.date));

const itemsByGroup = groupSections.map((section) => ({
  ...section,
  items: items
    .filter((entry) => entry.data.group === section.id)
    .sort((a, b) => section.order.indexOf(a.slug) - section.order.indexOf(b.slug)),
})).filter((section) => section.items.length > 0);
---
<Base title="Community — Keith Curry" description="Community work, events, and organizing experience by Keith Curry.">
  <section class="archive-hero">
    <p class="page-eyebrow">Community</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Community</h1>
    <p class="lede mt-4 max-w-2xl">Organizations, programs, and public-facing work around engineering, AI, science, and internet infrastructure.</p>
    <div class="archive-tags">
      <span class="folio-chip">Organizations</span>
      <span class="folio-chip">Leadership</span>
      <span class="folio-chip">Public engagement</span>
    </div>
  </section>
  <div class="mt-10 space-y-12">
    {itemsByGroup.map((section) => (
      <section aria-labelledby={`community-${section.id}`}>
        <div class="section-heading mb-5">
          <p class="page-eyebrow">Community</p>
          <h2 id={`community-${section.id}`} class="text-2xl font-semibold tracking-tight sm:text-3xl">{section.label}</h2>
          <p class="text-sm leading-7 text-zinc-600 dark:text-zinc-300">{section.summary}</p>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {section.items.map(({ slug, data }) => (
            <SimpleCard url={`/community/${slug}`} data={data} eyebrow={data.kind === "event" ? "Event" : "Organization"} />
          ))}
        </div>
      </section>
    ))}
  </div>
</Base>
