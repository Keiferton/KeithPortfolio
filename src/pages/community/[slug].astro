---
import Base from "@/layouts/Base.astro";
import ContactCTA from "@/components/ContactCTA.astro";
import { getCollection } from "astro:content";
import { buildBreadcrumbJsonLd, buildCreativeWorkJsonLd } from "@/lib/seo";
export async function getStaticPaths() {
  const entries = await getCollection("community");
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const d = entry.data;
const { Content } = await entry.render();
const prettyDate = (iso?: string) => iso ? new Date(`${iso}T12:00:00`).toLocaleDateString(undefined,{year:"numeric",month:"short"}) : "";
const pagePath = Astro.url.pathname;
const galleryImages = Array.from(new Set([d.cover, ...(d.thumbs ?? [])].filter(Boolean))) as string[];
const previewImage = galleryImages[0];
const pageDescription = d.summary ?? `${d.title} community work by Keith Curry.`;
const keywords = [d.org, d.role].filter((value): value is string => Boolean(value));
const itemTypeLabels = {
  role: "Role",
  event: "Event",
  talk: "Talk",
  service: "Service",
};
const jsonLd = [
  buildBreadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "Community", path: "/community" },
    { name: d.title, path: pagePath },
  ]),
  buildCreativeWorkJsonLd({
    type: "Article",
    title: d.title,
    description: pageDescription,
    path: pagePath,
    image: previewImage,
    date: d.date,
    keywords,
    section: "Community",
  }),
];
---
<Base
  title={`${d.title} — Community`}
  description={pageDescription}
  image={previewImage}
  type="article"
  jsonLd={jsonLd}
>
  <article class="prose prose-zinc dark:prose-invert max-w-none">
    <a href="/community" class="text-sm underline">← Back to Community</a>
    <header class="mt-2">
      <h1 class="mb-2">{d.title}</h1>
      <div class="text-sm text-zinc-600 dark:text-zinc-400 flex gap-3 flex-wrap">
        {d.org && <span>Org: <span class="font-medium text-zinc-800 dark:text-zinc-100">{d.org}</span></span>}
        {d.role && <span>Role: <span class="font-medium text-zinc-800 dark:text-zinc-100">{d.role}</span></span>}
        {d.date && <span>When: <span class="font-medium text-zinc-800 dark:text-zinc-100">{prettyDate(d.date)}</span></span>}
      </div>
    </header>

    {galleryImages.length === 1 && (
      <img src={galleryImages[0]} alt={d.title} class="rounded-xl my-4 w-full max-w-xl mx-auto h-auto" loading="lazy" decoding="async" />
    )}

    {galleryImages.length > 1 && (
      <div class="not-prose community-gallery my-6" data-community-gallery>
        <div class="community-gallery__stage">
          <img
            src={galleryImages[0]}
            alt={`${d.title} image 1`}
            class="community-gallery__image"
            data-gallery-image
            loading="lazy"
            decoding="async"
          />
          <button class="community-gallery__control community-gallery__control--prev" type="button" data-gallery-prev aria-label="Previous image">‹</button>
          <button class="community-gallery__control community-gallery__control--next" type="button" data-gallery-next aria-label="Next image">›</button>
        </div>
        <div class="community-gallery__meta">
          <span data-gallery-counter>1 / {galleryImages.length}</span>
        </div>
        <div class="community-gallery__thumbs" aria-label={`${d.title} gallery thumbnails`}>
          {galleryImages.map((src: string, i: number) => (
            <button
              class="community-gallery__thumb"
              type="button"
              data-gallery-thumb
              data-src={src}
              data-alt={`${d.title} image ${i + 1}`}
              data-index={i}
              aria-label={`Show image ${i + 1}`}
              aria-current={i === 0 ? "true" : "false"}
            >
              <img src={src} alt="" loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      </div>
    )}

    {Array.isArray(d.items) && d.items.length > 0 && (
      <section class="not-prose community-items my-8" aria-labelledby="community-items-heading">
        <h2 id="community-items-heading" class="text-2xl font-semibold tracking-tight">Selected work</h2>
        <div class="mt-4 grid gap-4">
          {d.items.map((item) => (
            <article class="community-item">
              <div class="flex flex-wrap items-center gap-2">
                <span class="folio-chip">{itemTypeLabels[item.type]}</span>
                {item.date && <span class="folio-date">{prettyDate(item.date)}</span>}
              </div>
              <h3 class="mt-3 text-xl font-semibold">{item.title}</h3>
              {item.role && <p class="mt-1 text-sm font-medium text-zinc-700 dark:text-zinc-200">{item.role}</p>}
              <p class="mt-2 text-sm leading-7 text-zinc-600 dark:text-zinc-300">{item.summary}</p>
              {item.links && (item.links.site || item.links.gallery) && (
                <div class="mt-3 flex flex-wrap gap-3 text-sm">
                  {item.links.site && <a class="underline text-zinc-800 dark:text-zinc-100" href={item.links.site} target="_blank" rel="noopener">Website</a>}
                  {item.links.gallery && <a class="underline text-zinc-800 dark:text-zinc-100" href={item.links.gallery} target="_blank" rel="noopener">Gallery</a>}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {/* Links */}
    {d.links && (d.links.site || d.links.gallery) && (
      <div class="my-4 p-4 bg-gray-50 dark:bg-zinc-800 rounded-lg border border-zinc-200 dark:border-zinc-600">
        <h2 class="text-lg font-semibold mb-2">Links</h2>
        <ul class="space-y-1">
          {d.links.site && <li><a class="underline text-zinc-800 dark:text-zinc-100" href={d.links.site} target="_blank" rel="noopener">Website</a></li>}
          {d.links.gallery && <li><a class="underline text-zinc-800 dark:text-zinc-100" href={d.links.gallery} target="_blank" rel="noopener">Gallery</a></li>}
        </ul>
      </div>
    )}

    <Content />

    <div class="not-prose mt-10">
      <ContactCTA />
    </div>
  </article>
</Base>

<script is:inline>
  document.querySelectorAll("[data-community-gallery]").forEach((gallery) => {
    const image = gallery.querySelector("[data-gallery-image]");
    const counter = gallery.querySelector("[data-gallery-counter]");
    const thumbs = Array.from(gallery.querySelectorAll("[data-gallery-thumb]"));
    const previous = gallery.querySelector("[data-gallery-prev]");
    const next = gallery.querySelector("[data-gallery-next]");
    let activeIndex = 0;

    const setActive = (index) => {
      activeIndex = (index + thumbs.length) % thumbs.length;
      const activeThumb = thumbs[activeIndex];
      image.src = activeThumb.dataset.src;
      image.alt = activeThumb.dataset.alt;
      counter.textContent = `${activeIndex + 1} / ${thumbs.length}`;
      thumbs.forEach((thumb, thumbIndex) => {
        thumb.setAttribute("aria-current", thumbIndex === activeIndex ? "true" : "false");
      });
    };

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener("click", () => setActive(index));
    });
    previous.addEventListener("click", () => setActive(activeIndex - 1));
    next.addEventListener("click", () => setActive(activeIndex + 1));
  });
</script>
