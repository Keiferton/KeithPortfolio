---
import Base from "@/layouts/Base.astro";
import { siteMeta } from "@/lib/site";
---
<Base title="Contact — Keith Curry" description="Get in touch with Keith Curry about software engineering roles, collaborations, and research tooling work.">
  <Fragment slot="head">
    <link rel="dns-prefetch" href="https://assets.calendly.com" />
    <link rel="dns-prefetch" href="https://calendly.com" />
    <link rel="preconnect" href="https://assets.calendly.com" crossorigin />
    <link rel="preconnect" href="https://calendly.com" />
    <link
      rel="preload"
      as="script"
      href="https://assets.calendly.com/assets/external/widget.js"
      crossorigin
    />
    <script
      async
      src="https://assets.calendly.com/assets/external/widget.js"
      data-calendly-script="true"
    ></script>
  </Fragment>

  <section class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1.28fr)_minmax(18rem,0.72fr)] lg:items-start">
    <div class="surface-panel px-6 py-8 sm:px-8 sm:py-10">
      <p class="page-eyebrow">Contact</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Let&apos;s talk.</h1>
      <p class="lede mt-4 max-w-2xl">
        I&apos;m happy to talk about software engineering roles, research tooling, hardware projects, and community work.
      </p>

      <div class="mt-6">
        <div
          id="calendly-inline-root"
          class="mt-1"
          style="min-width:320px;height:760px;background:transparent;color-scheme:light;"
          aria-label="Calendly scheduling widget"
        ></div>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
      <a
        class="folio-card group"
        href={`mailto:${siteMeta.email}`}
      >
        <p class="folio-kicker">Email</p>
        <p class="folio-title">{siteMeta.email}</p>
        <p class="folio-summary">Best for roles, collaborations, and general inquiries.</p>
        <div class="folio-card__footer">Write a message</div>
      </a>

      <a
        class="folio-card group"
        href={siteMeta.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
      >
        <p class="folio-kicker">LinkedIn</p>
        <p class="folio-title">LinkedIn profile</p>
        <p class="folio-summary">Useful for career conversations and follow-up.</p>
        <div class="folio-card__footer">Open profile</div>
      </a>

      <a
        class="folio-card group"
        href={siteMeta.links.github}
        target="_blank"
        rel="noopener noreferrer"
      >
        <p class="folio-kicker">GitHub</p>
        <p class="folio-title">Browse code and experiments</p>
        <p class="folio-summary">Useful if you want to see implementation details beyond the portfolio.</p>
        <div class="folio-card__footer">View repository work</div>
      </a>

      <a
        class="folio-card group"
        href="/KeithCurry_Resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
      >
        <p class="folio-kicker">Resume</p>
        <p class="folio-title">Download the quick summary</p>
        <p class="folio-summary">A concise view of experience, technical focus, and recent work.</p>
        <div class="folio-card__footer">Open PDF</div>
      </a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.getElementById("calendly-inline-root");
      if (!root) return;

      const calendlyUrl = "https://calendly.com/keifh/intro";
      let lastTheme = "";

      const hexValue = (value) => value.trim().replace(/^#/, "");

      const getThemePalette = () => {
        const styles = getComputedStyle(document.documentElement);

        return {
          background: hexValue(styles.getPropertyValue("--paper-panel")),
          text: hexValue(styles.getPropertyValue("--ink")),
          primary: hexValue(styles.getPropertyValue("--accent-cool")),
        };
      };

      const buildCalendlyUrl = () => {
        const palette = getThemePalette();
        const url = new URL(calendlyUrl);

        url.searchParams.set("background_color", palette.background);
        url.searchParams.set("text_color", palette.text);
        url.searchParams.set("primary_color", palette.primary);

        return url.toString();
      };

      const resolvedTheme = () =>
        document.documentElement.classList.contains("dark") ? "dark" : "light";

      const ensureCalendly = () =>
        new Promise((resolve, reject) => {
          if (window.Calendly?.initInlineWidget) {
            resolve(window.Calendly);
            return;
          }

          const existing = document.querySelector('script[data-calendly-script="true"]');
          if (existing) {
            existing.addEventListener("load", () => resolve(window.Calendly), { once: true });
            existing.addEventListener("error", reject, { once: true });
            return;
          }

          const script = document.createElement("script");
          script.src = "https://assets.calendly.com/assets/external/widget.js";
          script.async = true;
          script.dataset.calendlyScript = "true";
          script.addEventListener("load", () => resolve(window.Calendly), { once: true });
          script.addEventListener("error", reject, { once: true });
          document.body.appendChild(script);
        });

      const styleCalendlyChrome = () => {
        const widget = root.firstElementChild;
        if (widget instanceof HTMLElement) {
          widget.style.background = "transparent";
          widget.style.colorScheme = "light";
        }

        const iframe = root.querySelector("iframe");
        if (iframe instanceof HTMLIFrameElement) {
          iframe.style.backgroundColor = "transparent";
          iframe.style.border = "0";
          iframe.style.borderRadius = "20px";
          iframe.style.colorScheme = "light";
          iframe.style.display = "block";
        }
      };

      const renderCalendly = async (theme) => {
        if (theme === lastTheme && root.childElementCount > 0) return;

        try {
          const Calendly = await ensureCalendly();
          if (!Calendly?.initInlineWidget) return;

          root.innerHTML = "";
          Calendly.initInlineWidget({
            url: buildCalendlyUrl(),
            parentElement: root,
            resize: true,
          });
          requestAnimationFrame(styleCalendlyChrome);
          window.setTimeout(styleCalendlyChrome, 250);
          lastTheme = theme;
        } catch (error) {
          console.error("Calendly failed to load.", error);
        }
      };

      renderCalendly(resolvedTheme());

      window.addEventListener("themechange", (event) => {
        const theme = event.detail?.resolved === "dark" ? "dark" : "light";
        renderCalendly(theme);
      });
    })();
  </script>
</Base>
