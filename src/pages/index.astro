---
import Base from "@/layouts/Base.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { siteMeta } from "@/lib/site";
import { getCollection } from "astro:content";

const [projects, products] = await Promise.all([
  getCollection("projects"),
  getCollection("products"),
]);

const priorityOrder: Record<string, number> = {
  moldiblocks: 0,
  "ir-light-pad": 1,
  "pol-patrol": 2,
  "stentorcam-v2": 3,
};
const featuredProjects = projects
  .filter(p => p.data.featured)
  .map(p => ({ url: `/projects/${p.slug}`, data: p.data, slug: p.slug, kind: "Case Study" }));
const featuredProducts = products
  .filter(p => p.data.featured)
  .map(p => ({ url: `/products/${p.slug}`, data: p.data, slug: p.slug, kind: "Product Build" }));
const featured = [...featuredProjects, ...featuredProducts].sort((a, b) => {
  const aKey = a.slug.toLowerCase();
  const bKey = b.slug.toLowerCase();
  const aRank = priorityOrder[aKey];
  const bRank = priorityOrder[bKey];
  if (Number.isInteger(aRank) && Number.isInteger(bRank)) return aRank - bRank;
  if (Number.isInteger(aRank)) return -1;
  if (Number.isInteger(bRank)) return 1;
  return b.data.date.localeCompare(a.data.date);
});

const practiceAreas = [
  "Research systems",
  "Infrastructure",
  "Fabrication",
];

const currentFocus = [
  "MoldiBlocks discovery",
  "Histology + TMA workflows",
  "Technical community",
  "AI-assisted automation",
];

const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteMeta.name,
    url: siteMeta.url,
    description: siteMeta.description,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: siteMeta.name,
    url: siteMeta.url,
    email: `mailto:${siteMeta.email}`,
    sameAs: [siteMeta.links.github, siteMeta.links.linkedin],
    knowsAbout: ["Software engineering", "Imaging systems", "3D printing", "Research tooling"],
  },
];

---
<Base
  title="Keith Curry — Portfolio"
  description="Software engineering, research tooling, and hardware projects by Keith Curry."
  jsonLd={homeJsonLd}
>
  <section class="surface-panel px-6 py-8 sm:px-8 sm:py-10">
    <div class="max-w-5xl">
      <p class="page-eyebrow">Keith Curry</p>
      <h1 class="display-title mt-4">I build low-cost systems across research, hardware, and infrastructure.</h1>
      <p class="lede mt-5 max-w-3xl">
        Software, hardware, and experimental workflows for reliability, access, and reproducibility.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#featured" class="button-primary inline-flex items-center px-4 py-2 text-sm">
          Featured Work
        </a>
        <a href="/work" class="button-secondary inline-flex items-center px-4 py-2 text-sm">
          All Work
        </a>
      </div>
      <div class="mt-6 flex flex-wrap gap-2">
        {practiceAreas.map((area) => (
          <span class="folio-chip">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="mt-8">
    <div class="surface-panel flex flex-col gap-3 px-5 py-4 sm:flex-row sm:items-center">
      <p class="page-eyebrow shrink-0">Currently</p>
      <div class="flex flex-wrap gap-2">
        {currentFocus.map((item) => (
          <span class="folio-chip">{item}</span>
        ))}
      </div>
    </div>
  </section>

  <section id="featured" class="mt-10">
    <div class="section-heading mb-6">
      <p class="page-eyebrow">Featured Work</p>
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">A few projects that show how I work.</h2>
      <p class="lede">
        Examples from research tooling, internal platform work, and fabrication.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {featured.map((item) => (
        <ProjectCard url={item.url} data={item.data} eyebrow={item.kind} />
      ))}
    </div>
  </section>
</Base>
