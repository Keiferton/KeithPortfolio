---
import Base from "@/layouts/Base.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { siteMeta } from "@/lib/site";
import { getCollection } from "astro:content";

const [projects, products, designs, community] = await Promise.all([
  getCollection("projects"),
  getCollection("products"),
  getCollection("designs"),
  getCollection("community"),
]);

const priorityOrder: Record<string, number> = {
  moldiblocks: 0,
  "ir-light-pad": 1,
  "pol-patrol": 2,
  "stentorcam-v2": 3,
};
const featuredProjects = projects
  .filter(p => p.data.featured)
  .map(p => ({ url: `/projects/${p.slug}/`, data: p.data, slug: p.slug }));
const featuredProducts = products
  .filter(p => p.data.featured)
  .map(p => ({ url: `/products/${p.slug}/`, data: p.data, slug: p.slug }));
const featured = [...featuredProjects, ...featuredProducts].sort((a, b) => {
  const aKey = a.slug.toLowerCase();
  const bKey = b.slug.toLowerCase();
  const aRank = priorityOrder[aKey];
  const bRank = priorityOrder[bKey];
  if (Number.isInteger(aRank) && Number.isInteger(bRank)) return aRank - bRank;
  if (Number.isInteger(aRank)) return -1;
  if (Number.isInteger(bRank)) return 1;
  return b.data.date.localeCompare(a.data.date);
});

const stats = [
  { value: projects.length, label: "projects" },
  { value: designs.length, label: "designs" },
  { value: products.length, label: "products" },
  { value: community.length, label: "community efforts" },
];

const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteMeta.name,
    url: siteMeta.url,
    description: siteMeta.description,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: siteMeta.name,
    url: siteMeta.url,
    email: `mailto:${siteMeta.email}`,
    sameAs: [siteMeta.links.github, siteMeta.links.linkedin],
    knowsAbout: ["Software engineering", "Imaging systems", "3D printing", "Research tooling"],
  },
];

---
<Base
  title="Keith Curry — Portfolio"
  description="Software engineering, research tooling, and hardware projects by Keith Curry."
  jsonLd={homeJsonLd}
>
  <section class="grid gap-10 lg:grid-cols-[minmax(0,1.5fr)_minmax(18rem,1fr)] lg:items-start">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500 dark:text-zinc-400">
        Software engineering, imaging systems, and fabrication
      </p>
      <h1 class="mt-3 max-w-4xl text-4xl font-bold tracking-tight sm:text-5xl">
        I build low-cost systems across research, hardware, and infrastructure.
      </h1>
      <p class="mt-4 max-w-2xl text-base text-zinc-600 dark:text-zinc-300">
        I'm Keith Curry, a Computer Science and Biology graduate building low-cost systems for 
        research and real-world use. My work sits at the intersection of hardware, software,
        and experimental workflows.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="#featured"
          class="inline-flex items-center rounded-full bg-zinc-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300"
        >
          View Featured Work
        </a>
        <a
          href="/about"
          class="inline-flex items-center rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-100 dark:hover:bg-zinc-800"
        >
          About Me
        </a>
        <a
          href="/contact"
          class="inline-flex items-center rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-100 dark:hover:bg-zinc-800"
        >
          Contact
        </a>
      </div>
      <div class="mt-8 flex flex-wrap gap-2 text-sm text-zinc-600 dark:text-zinc-300">
        <span class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-700">Imaging systems</span>
        <span class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-700">Research tooling</span>
        <span class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-700">3D design + fabrication</span>
        <span class="rounded-full border border-zinc-200 px-3 py-1 dark:border-zinc-700">Developer tooling</span>
      </div>
    </div>

    <aside class="rounded-2xl border border-zinc-200 bg-zinc-50/80 p-6 dark:border-zinc-700 dark:bg-zinc-800/70">
      <h2 class="text-lg font-semibold">At a glance</h2>
      <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
        Focused on software engineering at the intersection of code, tooling, and physical systems.
      </p>
      <dl class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
        {stats.map((stat) => (
          <div class="rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-700 dark:bg-zinc-900/80">
            <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500 dark:text-zinc-400">{stat.label}</dt>
            <dd class="mt-2 text-2xl font-semibold">{stat.value}</dd>
          </div>
        ))}
      </dl>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href="/KeithCurry_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full bg-zinc-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300"
        >
          Resume
        </a>
        <a
          href={siteMeta.links.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-100 dark:hover:bg-zinc-800"
        >
          LinkedIn
        </a>
      </div>
    </aside>
  </section>

  <section id="featured" class="mt-16">
    <h2 class="text-xl font-semibold mb-4">Featured</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {featured.map((item) => (
        <ProjectCard url={item.url} data={item.data} />
      ))}
    </div>
  </section>
</Base>
