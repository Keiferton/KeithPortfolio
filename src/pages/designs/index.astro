---
import Base from "@/layouts/Base.astro";
import DesignCard from "@/components/DesignCard.astro";
import { getCollection } from "astro:content";

const designs = (await getCollection("designs"))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---
<Base title="Designs — Keith Curry" description="3D designs, printable parts, and mechanical prototypes by Keith Curry.">
  <section class="archive-hero">
    <p class="page-eyebrow">Works / Designs</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Designs</h1>
    <p class="lede mt-4 max-w-2xl">Printable parts, enclosures, and mechanical iterations that support larger systems in the lab and beyond.</p>
    <div class="archive-tags">
      <span class="folio-chip">CAD files</span>
      <span class="folio-chip">Fabrication support</span>
      <span class="folio-chip">Interactive models</span>
    </div>
  </section>
  <div class="mt-10 grid md:grid-cols-2 gap-6">
    {designs.map(({ slug, data }) => (
      <DesignCard url={`/designs/${slug}/`} data={data} eyebrow="Design File" />
    ))}
  </div>
</Base>
