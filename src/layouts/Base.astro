---
import { siteMeta } from "@/lib/site";
import "@/styles/global.css";

const {
  title = siteMeta.name,
  description = siteMeta.description,
  image = siteMeta.defaultImage,
  type = "website",
  noindex = false,
  jsonLd = [],
} = Astro.props;

const siteUrl = Astro.site ?? new URL(siteMeta.url);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImage = image ? new URL(image, siteUrl).toString() : undefined;
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const themeOptions = [
  { value: "light", label: "Light" },
  { value: "dark", label: "Dark" },
  { value: "system", label: "System" },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImage && <meta property="og:image" content={socialImage} />}

    <meta name="twitter:card" content={socialImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}

    <slot name="head" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/kc-favicon.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/kc-favicon-dark.svg" media="(prefers-color-scheme: dark)" />
    <link rel="mask-icon" href="/kc-favicon.svg" color="#000000">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />


    <!-- Theme color support -->
    <meta id="theme-color-meta" name="theme-color" content="#f0eadf" />

    <script is:inline>
      (() => {
        const storageKey = "kc-theme-preference";
        const doc = document.documentElement;
        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

        const getStoredPreference = () => {
          try {
            const stored = localStorage.getItem(storageKey);
            return stored === "light" || stored === "dark" || stored === "system" ? stored : "system";
          } catch {
            return "system";
          }
        };

        const getResolvedTheme = (preference) => {
          if (preference === "system") {
            return mediaQuery.matches ? "dark" : "light";
          }
          return preference;
        };

        const applyTheme = (preference) => {
          const resolved = getResolvedTheme(preference);
          doc.dataset.theme = preference;
          doc.classList.toggle("dark", resolved === "dark");
          doc.style.colorScheme = resolved;

          const themeMeta = document.getElementById("theme-color-meta");
          if (themeMeta) {
            themeMeta.setAttribute("content", resolved === "dark" ? "#16120f" : "#f0eadf");
          }

          const logo = document.getElementById("site-logo");
          if (logo) {
            logo.setAttribute("src", resolved === "dark" ? "/kc-favicon-dark.svg" : "/kc-favicon.svg");
          }

          return resolved;
        };

        const setPreference = (preference) => {
          try {
            localStorage.setItem(storageKey, preference);
          } catch {}

          const resolved = applyTheme(preference);
          window.dispatchEvent(new CustomEvent("themechange", { detail: { preference, resolved } }));
        };

        const syncSystemTheme = () => {
          const preference = getStoredPreference();
          if (preference === "system") {
            const resolved = applyTheme(preference);
            window.dispatchEvent(new CustomEvent("themechange", { detail: { preference, resolved } }));
          }
        };

        mediaQuery.addEventListener("change", syncSystemTheme);

        window.__getThemePreference = getStoredPreference;
        window.__setThemePreference = setPreference;
        window.__applyThemePreference = applyTheme;

        applyTheme(getStoredPreference());
      })();
    </script>

    <script is:inline>
      (() => {
        const consentKey = "kc-cookie-consent";
        const measurementId = "G-W5L0W9H30X";
        let analyticsLoaded = false;

        window.dataLayer = window.dataLayer || [];
        window.gtag =
          window.gtag ||
          function () {
            window.dataLayer.push(arguments);
          };

        const gtag = window.gtag;

        const loadAnalytics = () => {
          if (analyticsLoaded) return;

          analyticsLoaded = true;

          const script = document.createElement("script");
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
          document.head.appendChild(script);

          gtag("js", new Date());
          gtag("config", measurementId, {
            page_path: window.location.pathname,
            anonymize_ip: true,
          });
        };

        const applyAnalyticsConsent = (granted) => {
          gtag("consent", "default", {
            analytics_storage: "denied",
            ad_storage: "denied",
            ad_user_data: "denied",
            ad_personalization: "denied",
          });

          gtag("consent", "update", {
            analytics_storage: granted ? "granted" : "denied",
            ad_storage: "denied",
            ad_user_data: "denied",
            ad_personalization: "denied",
          });

          if (granted) {
            loadAnalytics();
          }
        };

        try {
          const stored = localStorage.getItem(consentKey);
          if (stored === "accepted") {
            applyAnalyticsConsent(true);
          } else {
            applyAnalyticsConsent(false);
          }
        } catch {
          applyAnalyticsConsent(false);
        }

        window.__setAnalyticsConsent = applyAnalyticsConsent;
      })();
    </script>

    <!-- <model-viewer> for GLB previews -->
    <script is:inline type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

    {jsonLdItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)}></script>
    ))}
  </head>

  <body class="site-body min-h-screen text-zinc-900 dark:text-zinc-100">
    <!-- HEADER -->
    <header class="site-header z-50">
      <nav class="mx-auto max-w-6xl px-4 py-3 flex items-center gap-3">
        <!-- Brand / Home -->
        <a href="/" aria-label="Home" title="Home" class="brand-link flex items-center gap-3 rounded-2xl px-2 py-2">
          <img id="site-logo" src="/kc-favicon.svg" alt="KC Logo" class="w-10 h-10" />
          <span class="site-name hidden sm:flex flex-col">
            <span class="text-base font-semibold">{siteMeta.name}</span>
            <span class="site-tagline">Research / Software / Hardware</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden sm:flex items-center gap-5">
          <a href="/work" class="nav-link">Works</a>
          <a href="/community" class="nav-link">Community</a>
          <a href="/about" class="nav-link">About</a>
          <a href="/contact" class="nav-link">Contact</a>
        </div>

        <!-- Spacer -->
        <div class="ml-auto"></div>

        <!-- Icons (always visible) -->
        <div class="flex items-center gap-2">
          <div class="theme-toggle hidden md:flex" role="group" aria-label="Theme preference">
            {themeOptions.map((option) => (
              <button
                type="button"
                class="theme-toggle__button"
                data-theme-value={option.value}
                aria-pressed="false"
                aria-label={option.label}
                title={option.label}
              >
                {option.value === "light" ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <circle cx="12" cy="12" r="4"></circle>
                    <path stroke-linecap="round" d="M12 2v2.5M12 19.5V22M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M2 12h2.5M19.5 12H22M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77"></path>
                  </svg>
                ) : option.value === "dark" ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <rect x="3.5" y="4.5" width="17" height="12" rx="2"></rect>
                    <path stroke-linecap="round" d="M8 19.5h8M10 16.5v3M14 16.5v3"></path>
                  </svg>
                )}
                <span class="sr-only">{option.label}</span>
              </button>
            ))}
          </div>

          <a
            href="/KeithCurry_Resume.pdf"
            download
            class="button-download hidden sm:inline-flex items-center px-4 py-2 text-sm"
          >
            Download Resume
          </a>

          <!-- GitHub -->
          <a
            href={siteMeta.links.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            title="GitHub"
            class="nav-icon-link rounded-xl p-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                class="w-5 h-5 text-zinc-700 dark:text-zinc-200">
              <path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"
                d="M12.026 2c-5.509 0-9.974 4.465-9.974 9.974 0 4.406 2.857 8.145 6.821 9.465.499.09.679-.217.679-.481 0-.237-.008-.865-.011-1.696-2.775.602-3.361-1.338-3.361-1.338-.452-1.152-1.107-1.459-1.107-1.459-.905-.619.069-.605.069-.605 1.002.07 1.527 1.028 1.527 1.028.89 1.524 2.336 1.084 2.902.829.091-.645.351-1.085.635-1.334-2.214-.251-4.542-1.107-4.542-4.93 0-1.087.389-1.979 1.024-2.675-.101-.253-.446-1.268.099-2.64 0 0 .837-.269 2.742 1.021a9.582 9.582 0 0 1 2.496-.336 9.554 9.554 0 0 1 2.496.336c1.906-1.291 2.742-1.021 2.742-1.021.545 1.372.203 2.387.099 2.64.64.696 1.024 1.587 1.024 2.675 0 3.833-2.33 4.675-4.552 4.922.355.308.675.916.675 1.846 0 1.334-.012 2.41-.012 2.737 0 .267.178.577.687.479C19.146 20.115 22 16.379 22 11.974 22 6.465 17.535 2 12.026 2z"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a
            href={siteMeta.links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            title="LinkedIn"
            class="nav-icon-link rounded-xl p-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                class="w-5 h-5 text-zinc-700 dark:text-zinc-200 transition-colors duration-200">
              <circle cx="4.983" cy="5.009" r="2.188" fill="currentColor"></circle>
              <path d="M9.237 8.855v12.139h3.769v-6.003c0-1.584.298-3.118 2.262-3.118 1.937 0 1.961 1.811 1.961 3.218v5.904H21v-6.657c0-3.27-.704-5.783-4.526-5.783-1.835 0-3.065 1.007-3.568 1.96h-.051v-1.66H9.237zm-6.142 0H6.87v12.139H3.095z"
                    fill="currentColor"></path>
            </svg>
          </a>


          <!-- Mobile menu button -->
          <button
            id="nav-toggle"
            class="nav-icon-link sm:hidden rounded-xl p-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            type="button"
          >
            <!-- Hamburger icon -->
            <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16"/>
            </svg>
            <!-- Close icon (hidden by default) -->
            <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu (hidden on >= sm) -->
      <div id="mobile-menu" class="mobile-nav-panel sm:hidden hidden border-t dark:border-zinc-800">
        <div class="mx-auto max-w-6xl px-4 py-3 grid gap-3">
          <a href="/work" class="nav-link py-2">Works</a>
          <a href="/community" class="nav-link py-2">Community</a>
          <a href="/about" class="nav-link py-2">About</a>
          <a href="/contact" class="nav-link py-2">Contact</a>
          <a href="/KeithCurry_Resume.pdf" download class="nav-link py-2">Download Resume</a>
          <div class="pt-2">
            <p class="nav-link">Theme</p>
            <div class="theme-toggle mt-3" role="group" aria-label="Theme preference">
              {themeOptions.map((option) => (
                <button
                  type="button"
                  class="theme-toggle__button"
                  data-theme-value={option.value}
                  aria-pressed="false"
                  aria-label={option.label}
                  title={option.label}
                >
                  {option.value === "light" ? (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <circle cx="12" cy="12" r="4"></circle>
                      <path stroke-linecap="round" d="M12 2v2.5M12 19.5V22M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M2 12h2.5M19.5 12H22M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77"></path>
                    </svg>
                  ) : option.value === "dark" ? (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <rect x="3.5" y="4.5" width="17" height="12" rx="2"></rect>
                      <path stroke-linecap="round" d="M8 19.5h8M10 16.5v3M14 16.5v3"></path>
                    </svg>
                  )}
                  <span class="sr-only">{option.label}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- MAIN -->
    <main class="portfolio-main mx-auto max-w-6xl px-4 py-10 sm:py-12">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="site-footer mx-auto max-w-6xl px-4 py-10 text-sm text-zinc-500 dark:text-zinc-400">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="space-y-1 text-center sm:text-left">
          <p>© {new Date().getFullYear()} Keith Curry</p>
          <p>Last updated {new Date().toISOString().slice(0,10)}</p>
        </div>

        <!-- stacked on mobile, row on desktop -->
        <div class="flex flex-col items-center gap-3 text-center sm:flex-row sm:items-center sm:gap-5 sm:text-left">
          <a href="/contact" class="underline">Contact</a>
          <a href={`mailto:${siteMeta.email}`} class="underline">Email</a>
          <a href="/KeithCurry_Resume.pdf" target="_blank" rel="noopener noreferrer" class="underline">Resume</a>
          <a href="/KeithCurry_CV.pdf" target="_blank" rel="noopener noreferrer" class="underline">Curriculum Vitae (CV)</a>
          <button type="button" data-cookie-settings class="underline bg-transparent border-0 p-0 cursor-pointer">Cookie settings</button>

          <!-- GitHub (icon + label) -->
          <a
            href={siteMeta.links.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            title="GitHub"
            class="inline-flex items-center gap-2 p-2 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 class="w-5 h-5 text-zinc-700 dark:text-zinc-200">
              <path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"
                d="M12.026 2c-5.509 0-9.974 4.465-9.974 9.974 0 4.406 2.857 8.145 6.821 9.465.499.09.679-.217.679-.481 0-.237-.008-.865-.011-1.696-2.775.602-3.361-1.338-3.361-1.338-.452-1.152-1.107-1.459-1.107-1.459-.905-.619.069-.605.069-.605 1.002.07 1.527 1.028 1.527 1.028.89 1.524 2.336 1.084 2.902.829.091-.645.351-1.085.635-1.334-2.214-.251-4.542-1.107-4.542-4.93 0-1.087.389-1.979 1.024-2.675-.101-.253-.446-1.268.099-2.64 0 0 .837-.269 2.742 1.021a9.582 9.582 0 0 1 2.496-.336 9.554 9.554 0 0 1 2.496.336c1.906-1.291 2.742-1.021 2.742-1.021.545 1.372.203 2.387.099 2.64.64.696 1.024 1.587 1.024 2.675 0 3.833-2.33 4.675-4.552 4.922.355.308.675.916.675 1.846 0 1.334-.012 2.41-.012 2.737 0 .267.178.577.687.479C19.146 20.115 22 16.379 22 11.974 22 6.465 17.535 2 12.026 2z"/>
            </svg>
            <span>GitHub</span>
          </a>

          <!-- LinkedIn (icon + label) -->
          <a
            href={siteMeta.links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            title="LinkedIn"
            class="inline-flex items-center gap-2 p-2 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 class="w-5 h-5 text-zinc-700 dark:text-zinc-200">
              <circle cx="4.983" cy="5.009" r="2.188" fill="currentColor"></circle>
              <path d="M9.237 8.855v12.139h3.769v-6.003c0-1.584.298-3.118 2.262-3.118 1.937 0 1.961 1.811 1.961 3.218v5.904H21v-6.657c0-3.27-.704-5.783-4.526-5.783-1.835 0-3.065 1.007-3.568 1.96h-.051v-1.66H9.237zm-6.142 0H6.87v12.139H3.095z"
                    fill="currentColor"></path>
            </svg>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>
    </footer>

    <div id="cookie-banner" class="cookie-banner" hidden>
      <div class="cookie-banner__panel">
        <p class="page-eyebrow">Privacy</p>
        <h2 class="cookie-banner__title">Optional analytics</h2>
        <p class="cookie-banner__copy">
          This site can use Google Analytics to understand visits and improve the portfolio. The site works the same if you reject it.
        </p>
        <p id="cookie-banner-status" class="cookie-banner__status" aria-live="polite"></p>
        <div class="cookie-banner__actions">
          <button type="button" data-cookie-reject class="button-secondary inline-flex items-center justify-center px-4 py-2 text-sm">
            Reject
          </button>
          <button type="button" data-cookie-accept class="button-primary inline-flex items-center justify-center px-4 py-2 text-sm">
            Accept analytics
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu toggle script -->
    <script>
      const btn = document.getElementById('nav-toggle');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');
      const themeApi = window as Window & {
        __getThemePreference?: () => string;
        __setThemePreference?: (preference: string) => void;
        __applyThemePreference?: (preference: string) => string;
        __setAnalyticsConsent?: (granted: boolean) => void;
      };
      const consentStorageKey = 'kc-cookie-consent';
      const consentAnimationMs = 220;
      const themeButtons = Array.from(document.querySelectorAll('[data-theme-value]'));
      const consentBanner = document.getElementById('cookie-banner');
      const consentStatus = document.getElementById('cookie-banner-status');
      const acceptConsentButtons = Array.from(document.querySelectorAll('[data-cookie-accept]'));
      const rejectConsentButtons = Array.from(document.querySelectorAll('[data-cookie-reject]'));
      const settingsButtons = Array.from(document.querySelectorAll('[data-cookie-settings]'));
      let consentCloseTimer: number | undefined;

      const syncThemeButtons = () => {
        const preference = typeof themeApi.__getThemePreference === 'function' ? themeApi.__getThemePreference() : 'system';
        if (typeof themeApi.__applyThemePreference === 'function') {
          themeApi.__applyThemePreference(preference);
        }

        themeButtons.forEach((button) => {
          const isActive = button.getAttribute('data-theme-value') === preference;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-pressed', String(isActive));
        });
      };

      const getStoredConsent = () => {
        try {
          const stored = localStorage.getItem(consentStorageKey);
          return stored === 'accepted' || stored === 'rejected' ? stored : null;
        } catch {
          return null;
        }
      };

      const updateConsentStatus = () => {
        if (!consentStatus) return;

        const stored = getStoredConsent();
        consentStatus.textContent =
          stored === 'accepted'
            ? 'Analytics is currently enabled.'
            : stored === 'rejected'
              ? 'Analytics is currently disabled.'
              : 'Analytics stays off until you choose.';
      };

      const syncConsentControls = () => {
        const hasChoice = getStoredConsent() !== null;
        settingsButtons.forEach((button) => {
          button.hidden = hasChoice;
        });
      };

      const openConsentBanner = () => {
        if (!consentBanner) return;

        if (typeof consentCloseTimer === 'number') {
          window.clearTimeout(consentCloseTimer);
          consentCloseTimer = undefined;
        }

        consentBanner.hidden = false;
        consentBanner.dataset.state = 'entering';
        updateConsentStatus();
        window.requestAnimationFrame(() => {
          if (!consentBanner.hidden) {
            consentBanner.dataset.state = 'open';
          }
        });
      };

      const closeConsentBanner = () => {
        if (!consentBanner) return;
        consentBanner.dataset.state = 'exiting';
        if (typeof consentCloseTimer === 'number') {
          window.clearTimeout(consentCloseTimer);
        }
        consentCloseTimer = window.setTimeout(() => {
          if (!consentBanner) return;
          consentBanner.hidden = true;
          consentBanner.dataset.state = 'closed';
        }, consentAnimationMs);
      };

      const setConsent = (value: 'accepted' | 'rejected') => {
        try {
          localStorage.setItem(consentStorageKey, value);
        } catch {}

        if (typeof themeApi.__setAnalyticsConsent === 'function') {
          themeApi.__setAnalyticsConsent(value === 'accepted');
        }

        syncConsentControls();
        updateConsentStatus();
        closeConsentBanner();
      };

      if (btn && menu && iconOpen && iconClose) {
        btn.addEventListener('click', () => {
          const isOpen = menu.classList.toggle('hidden') === false; // hidden removed => open
          btn.setAttribute('aria-expanded', String(isOpen));
          iconOpen.classList.toggle('hidden', isOpen);
          iconClose.classList.toggle('hidden', !isOpen);
        });
      }

      themeButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const themeValue = button.getAttribute('data-theme-value');
          if (typeof themeApi.__setThemePreference === 'function' && themeValue) {
            themeApi.__setThemePreference(themeValue);
          }
        });
      });

      settingsButtons.forEach((button) => {
        button.addEventListener('click', openConsentBanner);
      });

      acceptConsentButtons.forEach((button) => {
        button.addEventListener('click', () => setConsent('accepted'));
      });

      rejectConsentButtons.forEach((button) => {
        button.addEventListener('click', () => setConsent('rejected'));
      });

      window.addEventListener('themechange', syncThemeButtons);
      syncConsentControls();

      if (getStoredConsent() === null) {
        openConsentBanner();
      } else {
        updateConsentStatus();
        if (consentBanner) {
          consentBanner.hidden = true;
          consentBanner.dataset.state = 'closed';
        }
      }

      syncThemeButtons();
    </script>
  </body>
</html>
