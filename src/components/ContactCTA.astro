---
import { siteMeta } from "@/lib/site";

const {
  title = "Want to talk about this work?",
  body = "I like projects that sit between software, research tooling, and physical prototyping. If that overlaps with your work, feel free to reach out.",
} = Astro.props;
---

<section class="surface-panel p-6">
  <p class="page-eyebrow">Get in touch</p>
  <h2 class="mt-3 text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">{title}</h2>
  <p class="mt-3 max-w-2xl text-sm text-zinc-600 dark:text-zinc-300">{body}</p>
  <div class="mt-5 flex flex-wrap gap-3">
    <a
      href="/contact"
      class="button-primary inline-flex items-center px-4 py-2 text-sm"
    >
      Contact
    </a>
    <a
      href={`mailto:${siteMeta.email}`}
      class="button-secondary inline-flex items-center px-4 py-2 text-sm"
    >
      Email
    </a>
    <a
      href="/KeithCurry_Resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="button-secondary inline-flex items-center px-4 py-2 text-sm"
    >
      Resume
    </a>
  </div>
</section>
