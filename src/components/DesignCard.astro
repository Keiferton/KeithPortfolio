---
const { data, url, eyebrow = "Design File" } = Astro.props;
const glbPath = data.glbPath ?? null;
const prettyDate = data.date
  ? new Date(data.date).toLocaleDateString(undefined, { year: "numeric", month: "short" })
  : "";
---

<article class="folio-card group">
  <!-- Not clickable -->
  <div class="folio-card__media aspect-[4/3]">
    <model-viewer
      src={glbPath}
      camera-controls
      auto-rotate
      interaction-prompt="none"
      loading="lazy"
      style="background:transparent;"
    ></model-viewer>
  </div>

  <!-- Clickable section -->
  <div class="flex items-start justify-between gap-4">
    <p class="folio-kicker">{eyebrow}</p>
    {prettyDate && <p class="folio-date">{prettyDate}</p>}
  </div>
  <a href={url} class="mt-2 block">
    <h3 class="folio-title group-hover:underline">{data.title}</h3>

    {data.summary && (
      <p class="folio-summary">{data.summary}</p>
    )}

    {Array.isArray(data.tool) && data.tool.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {data.tool.map((t: string) => (
          <span class="folio-chip">{t}</span>
        ))}
      </div>
    )}
  </a>
  <div class="folio-card__footer">Inspect model</div>
</article>
