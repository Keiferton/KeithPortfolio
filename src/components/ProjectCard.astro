---
const { data, url, eyebrow = "Case Study" } = Astro.props;
const hasGlb = Boolean(data.glbPath);
const chips =
  Array.isArray(data.tech) && data.tech.length > 0
    ? data.tech
    : Array.isArray(data.tags) && data.tags.length > 0
      ? data.tags
      : [];
const prettyDate = data.date
  ? new Date(data.date).toLocaleDateString(undefined, { year: "numeric", month: "short" })
  : "";
---
<article class="folio-card group">
  {hasGlb ? (
    <div class="folio-card__media aspect-[4/3]">
      <model-viewer
        src={data.glbPath}
        camera-controls
        interaction-prompt="none"
        loading="lazy"
        style="background:transparent;"
      ></model-viewer>
    </div>
  ) : (
    data.cover && (
      <div class="folio-card__media aspect-[4/3]">
        <img src={data.cover} alt={data.title} class="h-full w-full object-cover" loading="lazy" decoding="async" />
      </div>
    )
  )}
  <div class="flex items-start justify-between gap-4">
    <p class="folio-kicker">{eyebrow}</p>
    {prettyDate && <p class="folio-date">{prettyDate}</p>}
  </div>
  <a href={url} class="mt-2 block">
    <h3 class="folio-title group-hover:underline">{data.title}</h3>
    <p class="folio-summary">{data.summary}</p>
  </a>
  {chips.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {chips.map((chip: string) => (
        <span class="folio-chip">
          {chip}
        </span>
      ))}
    </div>
  )}
  <div class="folio-card__footer">Read details</div>
</article>
