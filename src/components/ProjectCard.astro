---
const { data, url } = Astro.props;
const hasGlb = Boolean(data.glbPath);
const chips =
  Array.isArray(data.tech) && data.tech.length > 0
    ? data.tech
    : Array.isArray(data.tags) && data.tags.length > 0
      ? data.tags
      : [];
---
<div class="group flex h-full flex-col rounded-2xl border p-4 transition hover:shadow-lg">
  {hasGlb ? (
    <div class="mb-3 aspect-[4/3] overflow-hidden rounded-xl bg-zinc-50 dark:bg-zinc-800/60">
      <model-viewer
        src={data.glbPath}
        camera-controls
        interaction-prompt="none"
        loading="lazy"
        style="width:100%;height:100%;background:#f7f7f7;"
      ></model-viewer>
    </div>
  ) : (
    data.cover && (
      <div class="mb-3 aspect-[4/3] overflow-hidden rounded-xl bg-zinc-50 dark:bg-zinc-800/60">
        <img src={data.cover} alt={data.title} class="h-full w-full object-cover" loading="lazy" decoding="async" />
      </div>
    )
  )}
  <a href={url} class="block flex-1">
    <h3 class="font-semibold group-hover:underline">{data.title}</h3>
    <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-1">{data.summary}</p>
  </a>
  {chips.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {chips.map((chip: string) => (
        <span class="text-xs border border-zinc-300 dark:border-zinc-600 rounded px-2 py-0.5 text-zinc-700 dark:text-zinc-200">
          {chip}
        </span>
      ))}
    </div>
  )}
</div>
