---
const { url, data } = Astro.props;
const hasGlb = Boolean(data.glbPath);
---
<div class="group flex h-full flex-col rounded-2xl border p-4 hover:shadow-lg transition">
  {hasGlb ? (
    <div class="mb-3 aspect-[4/3] overflow-hidden rounded-xl bg-zinc-50 dark:bg-zinc-800/60">
      <model-viewer
        src={data.glbPath}
        camera-controls
        interaction-prompt="none"
        loading="lazy"
        style="width:100%;height:100%;background:#f7f7f7;"
      ></model-viewer>
    </div>
  ) : (
    data.cover && (
      <div class="mb-3 aspect-[4/3] overflow-hidden rounded-xl bg-zinc-50 dark:bg-zinc-800/60">
        <img
          src={data.cover}
          alt={data.title}
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    )
  )}

  <a href={url} class="block flex-1">
    <h3 class="font-semibold group-hover:underline">{data.title}</h3>
    {data.summary && <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-1">{data.summary}</p>}
  </a>
</div>
